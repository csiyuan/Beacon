# ─────────────────────────────────────────────────────────────────────────
# Local environment for /api/contact (form-to-email pipeline).
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored so secrets never leave your machine.
# ─────────────────────────────────────────────────────────────────────────

# Required. Get yours at https://resend.com/api-keys (free, no card).
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=

# Optional. Defaults to hello@beaconmediasolutions.com if unset.
# CONTACT_TO=hello@beaconmediasolutions.com

# Optional. Until you verify a domain in Resend, leave this unset and the
# emails will be sent from Resend's onboarding sender (onboarding@resend.dev).
# Once you verify a domain, switch this to e.g.:
#   CONTACT_FROM="Beacon <hello@beaconmediasolutions.com>"
# CONTACT_FROM=
